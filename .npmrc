# Keep the dependency tree strict but allow Astro's peer setup to resolve cleanly.
auto-install-peers=true
strict-peer-dependencies=false

# Hoist Sharp to the root node_modules so each app can resolve it for
# astro:assets image optimization (pnpm's strict isolation otherwise hides it,
# which fails the build at the "generating optimized images" step).
public-hoist-pattern[]=*sharp*

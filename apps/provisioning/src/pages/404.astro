---
import PageLayout from "@bali/ui/components/PageLayout.astro";
import { provisioning, provGeo } from "../brand";
---

<PageLayout
  brand={provisioning}
  current="404"
  title="Page Not Found | Bali Yacht Provisioning"
  description="The page you are looking for could not be found. Return to Bali Yacht Provisioning or submit your provisioning manifest."
  canonical="https://baliyachtprovisioning.com/"
  robots="noindex, follow"
  geo={provGeo}
>
  <section
    class="jc-hero section-tone--dark Section"
    data-screen-label="Provisioning · 404"
    style="min-height:72vh; display:flex; align-items:center; text-align:center; padding-top:calc(var(--header-height) + var(--space-30));"
  >
    <div style="margin:0 auto; max-width:60ch;">
      <span class="type-eyebrow" style="display:block; opacity:0.82;">404 · Not on the Manifest</span>
      <h1 class="type-h1" style="font-size:clamp(40px,5.6vw,68px); line-height:1.04; margin-top:30px;">This page isn't on the manifest.</h1>
      <p class="type-body-lg" style="opacity:0.84; margin-top:30px;">The page you requested has moved or never existed. We'll route you back, or submit your manifest and we'll handle the rest.</p>
      <div style="display:flex; gap:20px; margin-top:60px; flex-wrap:wrap; justify-content:center;">
        <a class="luxury-btn luxury-btn--solid luxury-btn--md" href="/">Back to Home</a>
        <a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/manifest#custom-lists">Submit Manifest</a>
      </div>
    </div>
  </section>
</PageLayout>

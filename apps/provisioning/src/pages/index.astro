---
import PageLayout from "@bali/ui/components/PageLayout.astro";
import ImagePlate from "@bali/ui/components/ImagePlate.astro";
import SisterBrands from "@bali/ui/components/SisterBrands.astro";
import { provisioning, provGeo } from "../brand";
import { img } from "../lib/images";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Bali Yacht Provisioning",
    description:
      "B2B superyacht provisioning and premium maritime F&B procurement at Bali Maritime Tourism Hub (Benoa Marina): wholesale sourcing for global superyacht crews.",
    url: "https://baliyachtprovisioning.com",
    telephone: "+62-811-3821-0187",
    areaServed: "Benoa Marina, Serangan Harbour & regional anchorages, Bali",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Komplek Ruko Wayang Sanur, Jl. Bypass Ngurah Rai",
      addressLocality: "Sanur, Denpasar",
      addressRegion: "Bali",
      postalCode: "80227",
      addressCountry: "ID",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Wholesale superyacht provisioning and maritime F&B procurement",
    name: "Premium Superyacht Provisioning & Maritime Procurement",
    description:
      "Bulk, commercial provisioning for superyachts: premium imports, fine wines and fresh local sourcing with dockside cold-chain delivery.",
    areaServed: "Bali: Benoa Marina & regional anchorages",
    provider: { "@type": "Organization", name: "Bali Yacht Provisioning", url: "https://baliyachtprovisioning.com" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Where do you deliver?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We deliver dockside to Bali Benoa Marina and Serangan Harbour, and coordinate to regional anchorages, with full customs and port-protocol compliance.",
        },
      },
      {
        "@type": "Question",
        name: "Can you handle large, bulk provisioning manifests?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. We are a B2B wholesale provisioner built for full superyacht manifests, from dry stores to fresh produce, premium imports and the cellar.",
        },
      },
      {
        "@type": "Question",
        name: "Do you source premium imports such as Wagyu and fine wine?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We source top-grade imported meats, artisanal cheeses, rare dry goods and an elite cellar of fine wines, Champagne and spirits to order.",
        },
      },
      {
        "@type": "Question",
        name: "How do you maintain the cold chain dockside?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Temperature-controlled transport and marine packing maintain an unbroken cold chain to the passerelle, maximising shelf life for long itineraries.",
        },
      },
    ],
  },
];
---

<PageLayout
  brand={provisioning}
  current="home"
  title="Bali Yacht Provisioning"
  description="World-class yacht provisioning at Bali Maritime Tourism Hub (Benoa Marina). High-end sourcing, premium imported ingredients, and fine wines for global superyachts."
  canonical="https://baliyachtprovisioning.com/"
  geo={provGeo}
  jsonLd={jsonLd}
>
  <section class="jc-hero section-tone--dark" data-screen-label="Provisioning · Home">
    <ImagePlate hero image={img("prov-home-hero")} caption="Superyacht at Benoa Marina / dockside provisioning" />
    <div class="jc-hero__scrim"></div>
    <div class="jc-hero__inner">
      <div class="jc-hero__col">
        <span class="type-eyebrow" style="display:block; margin-bottom:30px; opacity:0.82;">Superyacht Provisioning · Benoa Marina</span>
        <h1 class="type-h1" style="font-size:clamp(38px,5.4vw,64px); line-height:1.05; max-width:19ch;">Premium Superyacht Provisioning & Maritime Procurement in Bali</h1>
        <p class="type-body-lg" style="opacity:0.84; margin-top:30px; max-width:60ch;">World-class sourcing for elite superyacht crews: premium imports, fresh local produce and an elite cellar, delivered dockside under an unbroken cold chain.</p>
        <div style="display:flex; gap:20px; margin-top:60px; flex-wrap:wrap;">
          <a class="luxury-btn luxury-btn--solid luxury-btn--md" href="/manifest#custom-lists">Submit a Manifest</a>
          <a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/categories#premium-imported-proteins">Browse Categories</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Sourcing Global Luxury Ingredients for Elite Superyacht Crews</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:22ch;">A supply chain built for the cellar and the galley</h2>
    <p class="type-body-lg" style="margin:30px 0 0; max-width:64ch;">We procure to the manifest: top-grade imports, the daily catch, organic produce and rare dry goods, consolidated into a single, accurate, on-time delivery for the chief stewardess and chef.</p>
    <div class="jc-meta" style="margin-top:50px;">
      <span class="type-eyebrow" style="color:var(--accent);">Benoa Maritime Hub</span>
      <span class="type-eyebrow dot">/</span>
      <span class="type-eyebrow" style="color:var(--accent);">Cold-Chain Logistics</span>
      <span class="type-eyebrow dot">/</span>
      <span class="type-eyebrow" style="color:var(--accent);">Customs Compliant</span>
      <span class="type-eyebrow dot">/</span>
      <span class="type-eyebrow" style="color:var(--accent);">B2B Wholesale</span>
    </div>
  </section>

  <section class="section-tone--tint Section">
    <div class="jc-split">
      <div class="jc-split--text">
        <span class="type-eyebrow" style="display:block; color:var(--accent);">Direct Dockside Delivery to Bali Benoa Marina & Regional Anchorages</span>
        <h2 class="type-h2" style="margin:20px 0 0;">Delivered to the passerelle</h2>
        <p class="type-body-md" style="margin:30px 0 0;">Operating from the Bali Maritime Tourism Hub at Benoa, we deliver directly dockside and coordinate to Serangan and regional anchorages, clearing customs and port protocol so provisioning lands on schedule.</p>
        <div style="margin-top:40px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/port-logistics#delivery">Port Logistics</a></div>
      </div>
      <ImagePlate image={img("dockside-delivery-boxes")} caption="Dockside delivery / refrigerated transport" ratio="4 / 3" />
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Reliable B2B Solutions for Yacht Captains and Chefs</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:22ch;">Procurement, handled end to end</h2>
    <div class="luxury-card-grid" style="--cols:3; margin-top:50px;">
      <article class="luxury-card">
        <h3 class="luxury-card__title">Global Sourcing</h3>
        <p class="luxury-card__body">Premium imports and rare specialty goods sourced to spec: the brands and grades your chef asks for, found and delivered.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/categories#premium-imported-proteins">Categories</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Cold-Chain Logistics</h3>
        <p class="luxury-card__body">Temperature-controlled transport and marine packing keep an unbroken cold chain from store to passerelle.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/port-logistics#delivery">Logistics</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Manifest Processing</h3>
        <p class="luxury-card__body">Upload a manifest or shopping list; we price, source and confirm with the accuracy a long itinerary demands.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/manifest#custom-lists">Submit</a></div>
      </article>
    </div>
  </section>

  <section class="section-tone--dark Section" style="text-align:center;">
    <span class="type-eyebrow" style="display:block; opacity:0.82;">The Standard</span>
    <h2 class="type-h2" style="font-size:clamp(28px,4vw,46px); line-height:1.12; max-width:26ch; margin:30px auto 0;">One manifest, sourced precisely, delivered cold and on time.</h2>
    <p class="type-body-lg" style="opacity:0.82; max-width:58ch; margin:30px auto 0;">Captains and chefs run tight windows. We consolidate the entire provision into a single accountable delivery, every grade and brand confirmed.</p>
    <div style="margin-top:50px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/manifest#custom-lists">Submit a Manifest</a></div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Answers</span>
    <h2 class="type-h2" style="margin:20px 0 40px;">Frequently asked</h2>
    <div class="jc-faq">
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Where do you deliver?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">We deliver dockside to Bali Benoa Marina and Serangan Harbour, and coordinate to regional anchorages, with full customs and port-protocol compliance.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Can you handle large, bulk provisioning manifests?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Yes. We are a B2B wholesale provisioner built for full superyacht manifests, from dry stores to fresh produce, premium imports and the cellar.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Do you source premium imports such as Wagyu and fine wine?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">We source top-grade imported meats, artisanal cheeses, rare dry goods and an elite cellar of fine wines, Champagne and spirits to order.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">How do you maintain the cold chain dockside?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Temperature-controlled transport and marine packing maintain an unbroken cold chain to the passerelle, maximising shelf life for long itineraries.</p></div>
      </details>
    </div>
  </section>

  <SisterBrands
    current="prov"
    heading="Catering by air or by charter?"
    intro="Our sister brands deliver the same standard for private aviation and yacht charter dining in Bali."
  />
</PageLayout>

---
import PageLayout from "@bali/ui/components/PageLayout.astro";
import ImagePlate from "@bali/ui/components/ImagePlate.astro";
import SisterBrands from "@bali/ui/components/SisterBrands.astro";
import { provisioning, provGeo } from "../brand";
import { img } from "../lib/images";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Cold-chain port logistics and dockside delivery for superyachts",
    name: "Cold-Chain Port Logistics & Compliant Dockside Delivery",
    description:
      "Temperature-controlled cold-chain logistics and dockside delivery for superyachts at Bali Benoa Marina and Serangan Harbour, with full customs and port-protocol compliance.",
    areaServed: "Benoa Marina & Serangan Harbour, Bali",
    provider: { "@type": "Organization", name: "Bali Yacht Provisioning", url: "https://baliyachtprovisioning.com" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Which ports and anchorages do you serve?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We deliver directly to Benoa Marina and Serangan Harbour, and coordinate to regional anchorages around Bali.",
        },
      },
      {
        "@type": "Question",
        name: "How do you keep the cold chain unbroken?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Temperature-controlled transport and monitored handling maintain an unbroken cold chain from store to the passerelle.",
        },
      },
      {
        "@type": "Question",
        name: "Do you handle customs and port clearance?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. We operate with full customs and Benoa port-protocol compliance so delivery is friction-free for the crew.",
        },
      },
      {
        "@type": "Question",
        name: "Can you deliver to a tight departure window?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. Deliveries are scheduled to the berth and departure time, with around-the-clock coordination for last-minute changes.",
        },
      },
    ],
  },
];
---

<PageLayout
  brand={provisioning}
  current="logistics"
  title="Yacht Port Logistics & Dockside Delivery Bali | Benoa Marina"
  description="Specialized temperature-controlled cold-chain logistics for superyachts in Bali. Operating directly within Benoa Harbour with full customs & port protocol compliance."
  canonical="https://baliyachtprovisioning.com/port-logistics"
  geo={provGeo}
  jsonLd={jsonLd}
>
  <section class="jc-hero section-tone--dark" data-screen-label="Provisioning · Port Logistics" style="min-height:74vh;">
    <ImagePlate hero image={img("prov-log-hero")} caption="Refrigerated transport / Benoa harbour" />
    <div class="jc-hero__scrim"></div>
    <div class="jc-hero__inner">
      <div class="jc-hero__col">
        <span class="type-eyebrow" style="display:block; margin-bottom:30px; opacity:0.82;">Port Logistics & Cold Chain</span>
        <h1 class="type-h1" style="font-size:clamp(38px,5vw,62px); line-height:1.05; max-width:18ch;">Cold-Chain Port Logistics & Compliant Dockside Delivery</h1>
        <p class="type-body-lg" style="opacity:0.84; margin-top:30px; max-width:60ch;">Temperature-controlled, customs-cleared and scheduled to the berth — provisioning delivered to the passerelle with the cold chain intact.</p>
        <div style="display:flex; gap:20px; margin-top:50px; flex-wrap:wrap;">
          <a class="luxury-btn luxury-btn--solid luxury-btn--md" href="/manifest">Submit a Manifest</a>
          <a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/categories">Browse Categories</a>
        </div>
        <div class="jc-meta" style="margin-top:50px;">
          <span class="type-eyebrow">Benoa & Serangan</span>
          <span class="type-eyebrow dot">/</span>
          <span class="type-eyebrow">Unbroken Cold Chain</span>
          <span class="type-eyebrow dot">/</span>
          <span class="type-eyebrow">Customs Cleared</span>
          <span class="type-eyebrow dot">/</span>
          <span class="type-eyebrow">24 / 7 Coordination</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Delivering Directly to Bali Benoa Marina & Serangan Harbour</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:22ch;">From store to passerelle</h2>
    <p class="type-body-lg" style="margin:30px 0 60px; max-width:64ch;">Operating from the Bali Maritime Tourism Hub, we control the order from sourcing to dockside — a single accountable chain that lands provisioning where and when the crew needs it.</p>
    <div class="jc-steps">
      <div>
        <span class="jc-step__n">01</span>
        <h3 class="type-h3" style="margin:20px 0 0; font-size:22px;">Manifest & Schedule</h3>
        <p class="type-body-md" style="margin:12px 0 0; opacity:0.78;">We confirm the manifest, delivery window and berth with the chief stewardess or captain.</p>
      </div>
      <div>
        <span class="jc-step__n">02</span>
        <h3 class="type-h3" style="margin:20px 0 0; font-size:22px;">Source & Consolidate</h3>
        <p class="type-body-md" style="margin:12px 0 0; opacity:0.78;">Items are sourced, quality-checked and consolidated into one accountable order.</p>
      </div>
      <div>
        <span class="jc-step__n">03</span>
        <h3 class="type-h3" style="margin:20px 0 0; font-size:22px;">Cold Transport & Dockside</h3>
        <p class="type-body-md" style="margin:12px 0 0; opacity:0.78;">Temperature-controlled transport delivers to the passerelle, cleared and on schedule.</p>
      </div>
    </div>
  </section>

  <section class="section-tone--tint Section">
    <div class="jc-split">
      <div class="jc-split--text">
        <span class="type-eyebrow" style="display:block; color:var(--accent);">International Standard Temperature-Controlled Transport</span>
        <h2 class="type-h2" style="margin:20px 0 0;">A cold chain that never breaks</h2>
        <p class="type-body-md" style="margin:30px 0 0;">Chilled and frozen goods move under monitored, temperature-controlled transport from our facility to the dock — held to international standards and logged end to end, so what arrives is exactly as it left the store.</p>
        <div style="margin-top:40px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/manifest">Plan a Delivery</a></div>
      </div>
      <ImagePlate image={img("prov-log-plate1")} caption="Cold-chain handling / marine packing" ratio="4 / 3" />
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Custom Eco-Friendly Marine Packing for Maximum Shelf Life</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:24ch;">Packed for the itinerary</h2>
    <div class="luxury-card-grid" style="--cols:3; margin-top:50px;">
      <article class="luxury-card">
        <h3 class="luxury-card__title">Marine Packing</h3>
        <p class="luxury-card__body">Custom, eco-friendly marine packing protects fragile and chilled goods and reduces waste carried onboard.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/manifest">Enquire</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Maximum Shelf Life</h3>
        <p class="luxury-card__body">Cold-chain handling and considered packing extend freshness across long itineraries and remote legs.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/categories">Categories</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Customs & Port Protocol</h3>
        <p class="luxury-card__body">Full compliance with customs and Benoa port protocol for clearance and friction-free dockside delivery.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/manifest">Submit</a></div>
      </article>
    </div>
  </section>

  <section class="section-tone--dark Section" style="text-align:center;">
    <span class="type-eyebrow" style="display:block; opacity:0.82;">The Standard</span>
    <h2 class="type-h2" style="font-size:clamp(28px,4vw,46px); line-height:1.12; max-width:26ch; margin:30px auto 0;">Scheduled to the berth, cleared at the gate, cold to the passerelle.</h2>
    <p class="type-body-lg" style="opacity:0.82; max-width:58ch; margin:30px auto 0;">Logistics is the difference between a provision that arrives and one that arrives right. We own the chain end to end.</p>
    <div style="margin-top:50px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/manifest">Submit a Manifest</a></div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Answers</span>
    <h2 class="type-h2" style="margin:20px 0 40px;">Logistics questions</h2>
    <div class="jc-faq">
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Which ports and anchorages do you serve?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">We deliver directly to Benoa Marina and Serangan Harbour, and coordinate to regional anchorages around Bali.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">How do you keep the cold chain unbroken?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Temperature-controlled transport and monitored handling maintain an unbroken cold chain from store to the passerelle.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Do you handle customs and port clearance?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Yes. We operate with full customs and Benoa port-protocol compliance so delivery is friction-free for the crew.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Can you deliver to a tight departure window?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Yes. Deliveries are scheduled to the berth and departure time, with around-the-clock coordination for last-minute changes.</p></div>
      </details>
    </div>
  </section>

  <SisterBrands
    current="prov"
    heading="Catering by air or by charter?"
    intro="Our sister brands deliver the same standard for private aviation and yacht charter dining in Bali."
  />
</PageLayout>

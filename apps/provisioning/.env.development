# Local dev: resolve sister-brand cross-links to their localhost dev servers.
# Production builds use the real domains (defaults in @bali/ui/site-urls).
PUBLIC_JET_URL=http://localhost:4321
PUBLIC_YACHT_URL=http://localhost:4322
# No separate "events" app locally — point it at the group portal (4320) so the
# footer's "Bali Catering and Events" link stays on localhost during dev.
PUBLIC_EVENTS_URL=http://localhost:4320

---
import ArticleLayout from "@bali/ui/components/ArticleLayout.astro";
import { jet, jetGeo } from "../../brand";
import { articles } from "../../articles";
import { img } from "../../lib/images";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const related = articles
  .filter((a) => a.slug !== article.slug)
  .map((a) => ({
    slug: a.slug,
    title: a.title,
    category: a.category,
    readTime: a.readTime,
    excerpt: a.excerpt,
    image: img(a.imageSlot),
    ratio: "3 / 2",
  }));
---
<ArticleLayout
  brand={jet}
  article={article}
  image={img(article.imageSlot)}
  geo={jetGeo}
  cta={{ heading: "Have a flight on the board? Our dispatch desk is open around the clock." }}
  sister={{
    heading: "Operating on the water?",
    intro: "Catering or provisioning a yacht or superyacht in Bali? Our sister brands deliver the same standard dockside.",
  }}
  related={related}
/>

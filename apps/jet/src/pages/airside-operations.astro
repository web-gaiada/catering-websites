---
import PageLayout from "@bali/ui/components/PageLayout.astro";
import ImagePlate from "@bali/ui/components/ImagePlate.astro";
import SisterBrands from "@bali/ui/components/SisterBrands.astro";
import { jet, jetGeo } from "../brand";
import { img } from "../lib/images";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Airside catering logistics and FBO delivery",
    name: "Secure Airside Logistics & FBO Coordination",
    description:
      "Security-cleared airside delivery, HACCP food safety and flight-ready packaging for private aviation at Bali Ngurah Rai International (DPS/WADD).",
    areaServed: "Ngurah Rai International Airport (DPS/WADD), Bali",
    hoursAvailable: {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "23:59",
    },
    provider: { "@type": "FoodEstablishment", name: "Bali Jet Catering", url: "https://balijetcatering.com" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Do your crews hold airside access at Bali Ngurah Rai?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. Our delivery crews are security-cleared for airside access and coordinate directly with FBOs, ground handlers and dispatchers for apron delivery.",
        },
      },
      {
        "@type": "Question",
        name: "What turnaround times can you achieve?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Standard lead time is six hours; urgent and AOG-style turnarounds are handled around the clock, including last-minute manifest changes before departure.",
        },
      },
      {
        "@type": "Question",
        name: "How do you maintain the cold chain?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Meals are held and transported under temperature control in a monitored cold chain, packed in flight-ready high-vacuum packaging for low-humidity cabins.",
        },
      },
      {
        "@type": "Question",
        name: "Which terminals and handlers do you deliver to?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We deliver to ExecuJet General Aviation Terminal and coordinate with other FBOs, handlers and general aviation terminals across Ngurah Rai (DPS/WADD).",
        },
      },
    ],
  },
];
---

<PageLayout
  brand={jet}
  current="operations"
  title="Airside Logistics & FBO Aviation Delivery | Bali Jet Catering"
  description="Seamless airside logistics and security-cleared FBO delivery at Bali's airport. Fast turnaround times, strict HACCP food safety standards, and crew support."
  canonical="https://balijetcatering.com/airside-operations"
  geo={jetGeo}
  jsonLd={jsonLd}
>
  <section class="jc-hero section-tone--dark" data-screen-label="Jet · Airside Operations" style="min-height:74vh;">
    <ImagePlate hero image={img("jet-ops-hero")} caption="Apron / FBO ground operations at night" />
    <div class="jc-hero__scrim"></div>
    <div class="jc-hero__inner">
      <div class="jc-hero__col">
        <span class="type-eyebrow" style="display:block; margin-bottom:30px; opacity:0.82;">Airside Operations & Logistics</span>
        <h1 class="type-h1" style="font-size:clamp(38px,5vw,62px); line-height:1.05; max-width:18ch;">Secure Airside Logistics & FBO Coordination</h1>
        <p class="type-body-lg" style="opacity:0.84; margin-top:30px; max-width:60ch;">Security-cleared crews, a monitored cold chain and standing relationships with every FBO, so catering is delivered to the aircraft on time, every time.</p>
        <div style="display:flex; gap:20px; margin-top:50px; flex-wrap:wrap;">
          <a class="luxury-btn luxury-btn--solid luxury-btn--md" href="/contact#contact">Request a Quote</a>
          <a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/inflight-menus#fine-dining">View Inflight Menus</a>
        </div>
        <div class="jc-meta" style="margin-top:50px;">
          <span class="type-eyebrow">Airside Access</span>
          <span class="type-eyebrow dot">/</span>
          <span class="type-eyebrow">Monitored Cold Chain</span>
          <span class="type-eyebrow dot">/</span>
          <span class="type-eyebrow">HACCP-Controlled</span>
          <span class="type-eyebrow dot">/</span>
          <span class="type-eyebrow">24 / 7 Dispatch</span>
        </div>
      </div>
    </div>
  </section>

  <section id="airside-operations" class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">24/7 Delivery to ExecuJet General Aviation Terminal</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:22ch;">From order to apron, without friction</h2>
    <p class="type-body-lg" style="margin:30px 0 60px; max-width:64ch;">We coordinate directly with dispatchers, FBOs and ground handlers so the catering hand-off is a non-event: cleared, on schedule and stowed before doors close.</p>
    <div class="jc-steps">
      <div>
        <span class="jc-step__n">01</span>
        <h3 class="type-h3" style="margin:20px 0 0; font-size:22px;">Order & Confirm</h3>
        <p class="type-body-md" style="margin:12px 0 0; opacity:0.78;">Flight details, manifest and F&B requests are confirmed with a named dispatcher, 24/7.</p>
      </div>
      <div>
        <span class="jc-step__n">02</span>
        <h3 class="type-h3" style="margin:20px 0 0; font-size:22px;">Prepare & Pack</h3>
        <p class="type-body-md" style="margin:12px 0 0; opacity:0.78;">Prepared under HACCP control, labelled per passenger and crew, sealed in flight-ready packaging.</p>
      </div>
      <div>
        <span class="jc-step__n">03</span>
        <h3 class="type-h3" style="margin:20px 0 0; font-size:22px;">Clear & Deliver</h3>
        <p class="type-body-md" style="margin:12px 0 0; opacity:0.78;">Security-cleared crews deliver to the apron or FBO under temperature control, on your schedule.</p>
      </div>
    </div>
  </section>

  <section id="food-safety" class="section-tone--tint Section">
    <div class="jc-split">
      <div class="jc-split--text">
        <span class="type-eyebrow" style="display:block; color:var(--accent);">Strict HACCP & Flight-Ready High-Vacuum Packaging</span>
        <h2 class="type-h2" style="margin:20px 0 0;">Food safety, engineered for flight</h2>
        <p class="type-body-md" style="margin:30px 0 0;">Every order is prepared in a HACCP-controlled kitchen and sealed in high-vacuum, flight-ready packaging built for low-humidity cabins. Each tray is labelled with contents, allergens and reheating guidance, so the galley serves with total confidence.</p>
        <div style="margin-top:40px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/contact#contact">Request a Quote</a></div>
      </div>
      <ImagePlate image={img("jet-ops-plate1")} caption="Packaging / labelling / cold chain" ratio="4 / 3" />
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Rapid Turnarounds and Last-Minute Manifest Adjustments</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:24ch;">Built for the schedule that changes</h2>
    <div class="luxury-card-grid" style="--cols:3; margin-top:50px;">
      <article class="luxury-card">
        <h3 class="luxury-card__title">Rapid Turnarounds</h3>
        <p class="luxury-card__body">Six-hour standard lead time, with urgent and AOG-style turnarounds handled around the clock by a dedicated desk.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/contact#contact">Dispatch</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Manifest Adjustments</h3>
        <p class="luxury-card__body">Passenger counts, diets and timings change, and we expect it. Late changes are absorbed without compromising service.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/contact#contact">Enquire</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Crew & Cabin Support</h3>
        <p class="luxury-card__body">Galley restock, ice, water, amenities and crew meals: the whole cabin provision delivered in a single coordinated drop.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/contact#contact">Crew Catering</a></div>
      </article>
    </div>
  </section>

  <section class="section-tone--dark Section" style="text-align:center;">
    <span class="type-eyebrow" style="display:block; opacity:0.82;">The Standard</span>
    <h2 class="type-h2" style="font-size:clamp(28px,4vw,46px); line-height:1.12; max-width:24ch; margin:30px auto 0;">Catering is never the variable that holds a departure.</h2>
    <p class="type-body-lg" style="opacity:0.82; max-width:58ch; margin:30px auto 0;">A named dispatcher, a monitored cold chain and airside-cleared crews mean your order is met, quietly, exactly, at any hour.</p>
    <div style="margin-top:50px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/contact#contact">Speak With Dispatch</a></div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Answers</span>
    <h2 class="type-h2" style="margin:20px 0 40px;">Operations questions</h2>
    <div class="jc-faq">
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Do your crews hold airside access at Bali Ngurah Rai?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Yes. Our delivery crews are security-cleared for airside access and coordinate directly with FBOs, ground handlers and dispatchers for apron delivery.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">What turnaround times can you achieve?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Standard lead time is six hours; urgent and AOG-style turnarounds are handled around the clock, including last-minute manifest changes before departure.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">How do you maintain the cold chain?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Meals are held and transported under temperature control in a monitored cold chain, packed in flight-ready high-vacuum packaging for low-humidity cabins.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Which terminals and handlers do you deliver to?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">We deliver to ExecuJet General Aviation Terminal and coordinate with other FBOs, handlers and general aviation terminals across Ngurah Rai (DPS/WADD).</p></div>
      </details>
    </div>
  </section>

  <SisterBrands
    current="jet"
    heading="Operating on the water?"
    intro="Catering or provisioning a yacht or superyacht in Bali? Our sister brands deliver the same standard dockside."
  />
</PageLayout>

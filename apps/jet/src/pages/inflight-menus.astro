---
import PageLayout from "@bali/ui/components/PageLayout.astro";
import ImagePlate from "@bali/ui/components/ImagePlate.astro";
import SisterBrands from "@bali/ui/components/SisterBrands.astro";
import { jet, jetGeo } from "../brand";
import { img } from "../lib/images";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Menu",
    name: "Bali Jet Catering — Inflight Menus",
    description:
      "Curated multi-course inflight menus for private aviation: international and Indonesian fine dining, high-altitude flavor profiling, and specialized dietary programs.",
    url: "https://balijetcatering.com/inflight-menus",
    inLanguage: "en",
    provider: { "@type": "FoodEstablishment", name: "Bali Jet Catering", url: "https://balijetcatering.com" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "How far ahead do you need a custom menu?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Curated multi-course menus are best confirmed 24 hours ahead, though we routinely build bespoke menus on shorter notice. Standard à la carte selections begin at six hours.",
        },
      },
      {
        "@type": "Question",
        name: "Can you recreate a specific restaurant dish or a passenger favourite?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. Share the dish, a reference or a passenger profile and our chefs will develop and plate it for the cabin, accounting for altitude and service timing.",
        },
      },
      {
        "@type": "Question",
        name: "Do you provision wine, Champagne and spirits?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We supply a curated cellar — fine wines, Champagne and spirits — alongside water, soft beverages and barista-grade coffee service, subject to local regulation.",
        },
      },
      {
        "@type": "Question",
        name: "Can you cater for children and crew separately?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. We prepare distinct passenger, children and crew manifests, each labelled and packed for its own service window.",
        },
      },
    ],
  },
];
---

<PageLayout
  brand={jet}
  current="menus"
  title="Inflight Catering Menus | Gourmet Private Jet Food Bali"
  description="Explore our curated private jet catering menus. From multi-course international fine dining to specialized dietary needs (Keto, Halal, Vegan) for luxury flights out of Bali."
  canonical="https://balijetcatering.com/inflight-menus"
  geo={jetGeo}
  jsonLd={jsonLd}
>
  <section class="jc-hero section-tone--dark" data-screen-label="Jet · Inflight Menus" style="min-height:74vh;">
    <ImagePlate hero image={img("jet-menus-hero")} caption="Plated fine dining / caviar service" />
    <div class="jc-hero__scrim"></div>
    <div class="jc-hero__inner">
      <div class="jc-hero__col">
        <span class="type-eyebrow" style="display:block; margin-bottom:30px; opacity:0.82;">Inflight Menus · High-Altitude Gourmet</span>
        <h1 class="type-h1" style="font-size:clamp(38px,5vw,62px); line-height:1.05; max-width:18ch;">Curated Inflight Dining & Gourmet Jet Menus</h1>
        <p class="type-body-lg" style="opacity:0.84; margin-top:30px; max-width:60ch;">Multi-course menus designed for the executive cabin — sourced with provenance, engineered for altitude, and plated to hold from climb to descent.</p>
        <div style="display:flex; gap:20px; margin-top:50px; flex-wrap:wrap;">
          <a class="luxury-btn luxury-btn--solid luxury-btn--md" href="/contact">Request a Quote</a>
          <a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/airside-operations">Airside Operations</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">International & Indonesian Fine Dining for Executive Cabins</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:22ch;">A multi-course menu, composed for the cabin</h2>
    <p class="type-body-lg" style="margin:30px 0 50px; max-width:64ch;">Every menu is built to order. The selections below are a starting point — our chefs compose around passenger preference, occasion and flight length.</p>
    <div class="jc-list">
      <div class="jc-list__row">
        <span class="type-h3" style="font-size:20px;">Canapés & Caviar</span>
        <p class="type-body-md" style="opacity:0.78; margin:0;">Ossetra service, tuna tartare cornets, foie gras macarons and seasonal amuse-bouche for the first hour aloft.</p>
      </div>
      <div class="jc-list__row">
        <span class="type-h3" style="font-size:20px;">Starters</span>
        <p class="type-body-md" style="opacity:0.78; margin:0;">Burrata with heirloom tomato, hamachi crudo, or a warm consommé — plated to hold through climb and cruise.</p>
      </div>
      <div class="jc-list__row">
        <span class="type-h3" style="font-size:20px;">Mains · International</span>
        <p class="type-body-md" style="opacity:0.78; margin:0;">Wagyu tenderloin, butter-poached lobster, herb-crusted lamb rack or wild-caught fish, with refined seasonal sides.</p>
      </div>
      <div class="jc-list__row">
        <span class="type-h3" style="font-size:20px;">Mains · Indonesian</span>
        <p class="type-body-md" style="opacity:0.78; margin:0;">Bebek betutu, ikan bakar, nasi campur and rendang — sourced and seasoned for provenance and altitude.</p>
      </div>
      <div class="jc-list__row">
        <span class="type-h3" style="font-size:20px;">Patisserie & Dessert</span>
        <p class="type-body-md" style="opacity:0.78; margin:0;">Valrhona desserts, tropical fruit compositions and petit fours, finished with single-origin coffee service.</p>
      </div>
      <div class="jc-list__row">
        <span class="type-h3" style="font-size:20px;">Cellar & Cheese</span>
        <p class="type-body-md" style="opacity:0.78; margin:0;">Fine wines, Champagne and a curated cheese selection, packed discreetly for the cabin and crew.</p>
      </div>
    </div>
  </section>

  <section class="section-tone--tint Section">
    <div class="jc-split">
      <ImagePlate image={img("jet-menus-plate1")} caption="Plating / kitchen detail" ratio="4 / 3" />
      <div class="jc-split--text">
        <span class="type-eyebrow" style="display:block; color:var(--accent);">High-Altitude Flavor Profiling</span>
        <h2 class="type-h2" style="margin:20px 0 0;">Engineered for low humidity and cabin pressure</h2>
        <p class="type-body-md" style="margin:30px 0 0;">At altitude, the cabin dulls salt and sweetness and dries the palate. We season and compose accordingly — brighter acidity, considered fat, and textures that survive a galley reheat — so each course tastes as intended at 40,000 feet.</p>
        <div style="margin-top:40px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/contact">Discuss a Menu</a></div>
      </div>
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Specialized Dietary, Allergen-Safe & Custom Culinary Requests</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:24ch;">Every requirement, accounted for</h2>
    <div class="luxury-card-grid" style="--cols:3; margin-top:50px;">
      <article class="luxury-card">
        <h3 class="luxury-card__title">Dietary Programs</h3>
        <p class="luxury-card__body">Halal, vegan, vegetarian, keto, gluten-free, low-sodium and medical diets — composed without compromise to presentation.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/contact">Enquire</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Allergen Safety</h3>
        <p class="luxury-card__body">Prepared under HACCP control with segregated handling and per-passenger labelling, so the cabin crew can serve with confidence.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/airside-operations">Food Safety</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Bespoke Requests</h3>
        <p class="luxury-card__body">A signature dish, a celebration cake, a passenger favourite — share the brief and our chefs will design and plate it for the cabin.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/contact">Request</a></div>
      </article>
    </div>
  </section>

  <section class="section-tone--dark Section" style="text-align:center;">
    <span class="type-eyebrow" style="display:block; opacity:0.82;">Cellar & Beverage</span>
    <h2 class="type-h2" style="font-size:clamp(28px,4vw,46px); line-height:1.12; max-width:26ch; margin:30px auto 0;">A cellar packed for the cabin — from Champagne to barista coffee.</h2>
    <p class="type-body-lg" style="opacity:0.82; max-width:58ch; margin:30px auto 0;">Fine wines, Champagne, spirits and a full non-alcoholic programme, sourced and packed for service aloft, subject to local regulation.</p>
    <div style="margin-top:50px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/contact">Request a Quote</a></div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Answers</span>
    <h2 class="type-h2" style="margin:20px 0 40px;">Menu questions</h2>
    <div class="jc-faq">
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">How far ahead do you need a custom menu?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Curated multi-course menus are best confirmed 24 hours ahead, though we routinely build bespoke menus on shorter notice. Standard à la carte selections begin at six hours.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Can you recreate a specific restaurant dish or a passenger favourite?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Yes. Share the dish, a reference or a passenger profile and our chefs will develop and plate it for the cabin, accounting for altitude and service timing.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Do you provision wine, Champagne and spirits?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">We supply a curated cellar — fine wines, Champagne and spirits — alongside water, soft beverages and barista-grade coffee service, subject to local regulation.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Can you cater for children and crew separately?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Yes. We prepare distinct passenger, children and crew manifests, each labelled and packed for its own service window.</p></div>
      </details>
    </div>
  </section>

  <SisterBrands
    current="jet"
    heading="Operating on the water?"
    intro="Catering or provisioning a yacht or superyacht in Bali? Our sister brands deliver the same standard dockside."
  />
</PageLayout>

---
import PageLayout from "@bali/ui/components/PageLayout.astro";
import ImagePlate from "@bali/ui/components/ImagePlate.astro";
import SisterBrands from "@bali/ui/components/SisterBrands.astro";
import { jet, jetGeo } from "../brand";
import { img } from "../lib/images";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: "Bali Jet Catering — Insights",
    description:
      "Field notes on inflight catering craft, kitchen and airside operations from Bali Jet Catering at Ngurah Rai (DPS / WADD).",
    url: "https://balijetcatering.com/insights",
    publisher: { "@type": "Organization", name: "Bali Jet Catering", url: "https://balijetcatering.com" },
    blogPost: [
      {
        "@type": "BlogPosting",
        headline: "Why food tastes different at 40,000 feet",
        description:
          "How our chefs re-balance acidity, fat and texture so every course tastes as intended in a low-humidity, pressurised cabin.",
      },
      {
        "@type": "BlogPosting",
        headline: "Inside a 02:00 turnaround at ExecuJet Bali",
        description:
          "What it takes to clear catering to the apron when a manifest changes in the middle of the night.",
      },
      {
        "@type": "BlogPosting",
        headline: "Provenance at altitude: building a cabin pantry",
        description: "Where we source the grades and brands an executive cabin expects, and how they travel.",
      },
      {
        "@type": "BlogPosting",
        headline: "Allergen-safe service, without compromise",
        description: "How a HACCP-controlled kitchen prepares medical and allergen diets that still plate beautifully.",
      },
    ],
  },
];
---

<PageLayout
  brand={jet}
  current="insights"
  title="Insights & Field Notes | Private Jet Catering Bali"
  description="Field notes on inflight catering — high-altitude flavour, airside operations and provenance sourcing from Bali Jet Catering at Ngurah Rai (DPS / WADD)."
  canonical="https://balijetcatering.com/insights"
  geo={jetGeo}
  jsonLd={jsonLd}
>
  <section class="jc-hero section-tone--dark" data-screen-label="Jet · Insights" style="min-height:68vh;">
    <ImagePlate hero image={img("jet-insights-hero")} caption="Chef at the pass / plated detail close-up" />
    <div class="jc-hero__scrim"></div>
    <div class="jc-hero__inner">
      <div class="jc-hero__col">
        <span class="type-eyebrow" style="display:block; margin-bottom:30px; opacity:0.82;">Insights · Bali Jet Catering</span>
        <h1 class="type-h1" style="font-size:clamp(38px,5vw,62px); line-height:1.05; max-width:16ch;">Insights & field notes</h1>
        <p class="type-body-lg" style="opacity:0.84; margin-top:30px; max-width:58ch;">Notes on catering at altitude — the craft, the kitchen and the airside operations behind VVIP inflight dining out of Bali Ngurah Rai.</p>
        <div class="jc-meta" style="margin-top:50px;">
          <span class="type-eyebrow">Craft</span>
          <span class="type-eyebrow dot">/</span>
          <span class="type-eyebrow">Operations</span>
          <span class="type-eyebrow dot">/</span>
          <span class="type-eyebrow">Sourcing</span>
          <span class="type-eyebrow dot">/</span>
          <span class="type-eyebrow">Kitchen</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Latest from the maison</span>
    <h2 class="type-h2" style="margin:20px 0 50px; max-width:22ch;">Notes on catering at altitude</h2>
    <a class="jc-article-feature" href="#">
      <ImagePlate image={img("jet-insights-feature")} caption="Plated dish / chef seasoning" ratio="4 / 3" />
      <div class="jc-article-feature__text">
        <span class="type-eyebrow" style="display:block; color:var(--accent);">Craft · 6 min read</span>
        <h3 class="type-h2" style="margin:18px 0 0; font-size:clamp(26px,3vw,38px); line-height:1.12;">Why food tastes different at 40,000 feet</h3>
        <p class="type-body-md" style="opacity:0.78; margin:20px 0 0;">Low humidity and cabin pressure dull salt and sweetness and dry the palate. A look at how our chefs re-balance acidity, fat and texture so every course tastes as intended aloft.</p>
        <span class="type-eyebrow jc-read">Read article &rarr;</span>
      </div>
    </a>
  </section>

  <section class="section-tone--tint Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">More reading</span>
    <h2 class="type-h2" style="margin:20px 0 0;">From the apron and the kitchen</h2>
    <div class="luxury-card-grid" style="--cols:3; margin-top:50px;">
      <a class="jc-article-card" href="#">
        <ImagePlate image={img("jet-insights-tarmac")} caption="Tarmac / FBO at night" ratio="3 / 2" />
        <div class="jc-article-card__body">
          <span class="type-eyebrow" style="display:block; color:var(--accent);">Operations · 4 min read</span>
          <h3 class="type-h3" style="font-size:22px; line-height:1.28; margin:14px 0 0;">Inside a 02:00 turnaround at ExecuJet Bali</h3>
          <p class="type-body-md" style="opacity:0.74; margin:12px 0 0;">What it takes to clear catering to the apron when a manifest changes in the middle of the night.</p>
          <span class="type-eyebrow jc-read">Read article &rarr;</span>
        </div>
      </a>
      <a class="jc-article-card" href="#">
        <ImagePlate image={img("jet-insights-market")} caption="Market / premium ingredients" ratio="3 / 2" />
        <div class="jc-article-card__body">
          <span class="type-eyebrow" style="display:block; color:var(--accent);">Sourcing · 5 min read</span>
          <h3 class="type-h3" style="font-size:22px; line-height:1.28; margin:14px 0 0;">Provenance at altitude: building a cabin pantry</h3>
          <p class="type-body-md" style="opacity:0.74; margin:12px 0 0;">Where we source the grades and brands an executive cabin expects — and how they travel to the aircraft.</p>
          <span class="type-eyebrow jc-read">Read article &rarr;</span>
        </div>
      </a>
      <a class="jc-article-card" href="#">
        <ImagePlate image={img("jet-insights-kitchen")} caption="Kitchen detail / per-passenger labelling" ratio="3 / 2" />
        <div class="jc-article-card__body">
          <span class="type-eyebrow" style="display:block; color:var(--accent);">Kitchen · 3 min read</span>
          <h3 class="type-h3" style="font-size:22px; line-height:1.28; margin:14px 0 0;">Allergen-safe service, without compromise</h3>
          <p class="type-body-md" style="opacity:0.74; margin:12px 0 0;">How a HACCP-controlled kitchen prepares medical and allergen diets that still plate beautifully.</p>
          <span class="type-eyebrow jc-read">Read article &rarr;</span>
        </div>
      </a>
    </div>
  </section>

  <section class="section-tone--dark Section" style="text-align:center;">
    <span class="type-eyebrow" style="display:block; opacity:0.82;">The Journal</span>
    <h2 class="type-h2" style="font-size:clamp(28px,4vw,46px); line-height:1.12; max-width:26ch; margin:30px auto 0;">Field notes from the apron, the galley and the kitchen pass.</h2>
    <p class="type-body-lg" style="opacity:0.82; max-width:58ch; margin:30px auto 0;">Have a flight on the board? Our dispatch desk is open around the clock.</p>
    <div style="margin-top:50px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/contact">Speak With Dispatch</a></div>
  </section>

  <SisterBrands
    current="jet"
    heading="Operating on the water?"
    intro="Catering or provisioning a yacht or superyacht in Bali? Our sister brands deliver the same standard dockside."
  />
</PageLayout>

---
import PageLayout from "@bali/ui/components/PageLayout.astro";
import ImagePlate from "@bali/ui/components/ImagePlate.astro";
import SisterBrands from "@bali/ui/components/SisterBrands.astro";
import { jet, jetGeo } from "../brand";
import { img } from "../lib/images";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FoodEstablishment",
    name: "Bali Jet Catering",
    description:
      "VVIP inflight and private jet catering at Bali Ngurah Rai International Airport (DPS/WADD), with bespoke menus and 24/7 direct tarmac and FBO delivery.",
    url: "https://balijetcatering.com",
    telephone: "+62-811-3821-0187",
    servesCuisine: ["International", "Indonesian", "Fine Dining"],
    priceRange: "$$$$",
    areaServed: "Ngurah Rai International Airport (DPS/WADD), Bali",
    openingHoursSpecification: {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "23:59",
    },
    address: {
      "@type": "PostalAddress",
      streetAddress: "Komplek Ruko Wayang Sanur, Jl. Bypass Ngurah Rai",
      addressLocality: "Sanur, Denpasar",
      addressRegion: "Bali",
      postalCode: "80227",
      addressCountry: "ID",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "How quickly can you deliver catering to the aircraft?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We deliver directly to the apron and FBO at Bali Ngurah Rai. Standard lead times begin at six hours, and urgent turnarounds are accommodated around the clock through our dispatch desk.",
        },
      },
      {
        "@type": "Question",
        name: "Which airport and terminals do you serve?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We operate at Ngurah Rai International (DPS/WADD), delivering to ExecuJet General Aviation Terminal and to other FBOs, handlers and general aviation terminals across the airport.",
        },
      },
      {
        "@type": "Question",
        name: "Can you accommodate specialized diets and allergens?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. Halal, vegan, keto, low-sodium, medical and fully allergen-safe menus are prepared in a HACCP-controlled kitchen with per-passenger labelling.",
        },
      },
      {
        "@type": "Question",
        name: "How are meals packaged for flight?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Meals use flight-ready, high-vacuum packaging engineered for low-humidity cabins, labelled per passenger and crew, with reheating guidance for the galley.",
        },
      },
      {
        "@type": "Question",
        name: "What are your hours and how do we place an order?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Dispatch operates 24/7. Send flight details and F&B requests through the order form or the dispatch hotline. Last-minute manifest changes are expected and handled.",
        },
      },
    ],
  },
];
---

<PageLayout
  brand={jet}
  current="home"
  title="Bali Jet Catering"
  description="Ultra-luxury inflight catering for private aviation at Bali Ngurah Rai International Airport (DPS/WADD). Bespoke VVIP menus, 24/7 direct tarmac delivery."
  canonical="https://balijetcatering.com/"
  geo={jetGeo}
  jsonLd={jsonLd}
>
  <section class="jc-hero section-tone--dark" data-screen-label="Jet · Home">
    <ImagePlate hero image={img("jet-home-hero")} caption="Private jet on the apron at dusk" />
    <div class="jc-hero__scrim"></div>
    <div class="jc-hero__inner">
      <div class="jc-hero__col">
        <span class="type-eyebrow" style="display:block; margin-bottom:30px; opacity:0.82;">VVIP Inflight Catering · Ngurah Rai Intl · DPS / WADD</span>
        <h1 class="type-h1" style="font-size:clamp(40px,5.6vw,68px); line-height:1.04; max-width:18ch;">Inflight & Private Jet Catering in Bali</h1>
        <p class="type-body-lg" style="opacity:0.84; margin-top:30px; max-width:60ch;">Ultra-luxury inflight dining for private aviation, prepared to order and delivered tarmac-side at Bali Ngurah Rai International. Bespoke VVIP menus, cleared and onboard around the clock.</p>
        <div style="display:flex; gap:20px; margin-top:60px; flex-wrap:wrap;">
          <a class="luxury-btn luxury-btn--solid luxury-btn--md" href="/contact#contact">Request a Quote</a>
          <a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/inflight-menus#fine-dining">View Inflight Menus</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Premium Culinary Solutions for Private Aviation</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:20ch;">Catering engineered for the cabin, not the kitchen</h2>
    <p class="type-body-lg" style="margin:30px 0 0; max-width:64ch;">We cater exclusively for private and corporate aviation out of Bali. Every menu is built around the aircraft, the manifest and the moment of service, then delivered, cleared and stowed without a single point of friction on the ground.</p>
    <div class="jc-meta" style="margin-top:50px;">
      <span class="type-eyebrow" style="color:var(--accent);">Based at DPS / WADD</span>
      <span class="type-eyebrow dot">/</span>
      <span class="type-eyebrow" style="color:var(--accent);">24 / 7 Dispatch</span>
      <span class="type-eyebrow dot">/</span>
      <span class="type-eyebrow" style="color:var(--accent);">HACCP-Controlled Kitchen</span>
      <span class="type-eyebrow dot">/</span>
      <span class="type-eyebrow" style="color:var(--accent);">Security-Cleared Crews</span>
    </div>
  </section>

  <section class="section-tone--tint Section">
    <div class="jc-split">
      <div class="jc-split--text">
        <span class="type-eyebrow" style="display:block; color:var(--accent);">Direct Tarmac & FBO Delivery</span>
        <h2 class="type-h2" style="margin:20px 0 0;">Cleared to the apron at ExecuJet Bali GAT</h2>
        <p class="type-body-md" style="margin:30px 0 0;">Our crews hold airside access and arrive flight-ready: security-cleared, temperature-controlled and on schedule. We coordinate directly with dispatchers and handlers so catering is never the variable that holds a departure.</p>
        <div style="margin-top:40px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/airside-operations#airside-operations">Airside Operations</a></div>
      </div>
      <ImagePlate image={img("jet-home-plate1")} caption="Tarmac / FBO delivery" ratio="4 / 3" />
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Bespoke Menus, Tailored to the Manifest</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:22ch;">Dining matched to every passenger profile</h2>
    <div class="luxury-card-grid" style="--cols:3; margin-top:50px;">
      <article class="luxury-card">
        <h3 class="luxury-card__title">International & Indonesian Fine Dining</h3>
        <p class="luxury-card__body">Multi-course menus from classical European service to refined Indonesian provenance, plated for the executive cabin.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/inflight-menus#fine-dining">View Menus</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Specialized & Allergen-Safe</h3>
        <p class="luxury-card__body">Halal, vegan, keto, low-sodium and medical diets, prepared under strict allergen control with full per-passenger labelling.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/dietary-and-allergen-safe#dietary-program">Dietary Options</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Crew, Cabin & Provisioning</h3>
        <p class="luxury-card__body">Crew meals, galley restock, fine wines, water and amenities: a complete cabin provision delivered in one manifest.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/crew-and-provisioning#complete-cabin-provision">Crew Catering</a></div>
      </article>
    </div>
  </section>

  <section class="section-tone--dark Section" style="text-align:center;">
    <span class="type-eyebrow" style="display:block; opacity:0.82;">The Standard</span>
    <h2 class="type-h2" style="font-size:clamp(28px,4vw,46px); line-height:1.12; max-width:24ch; margin:30px auto 0;">When the manifest changes at 02:00, we are already in the kitchen.</h2>
    <p class="type-body-lg" style="opacity:0.82; max-width:58ch; margin:30px auto 0;">Reliability is the product. A dedicated dispatch desk, redundant cold chain and standing relationships with every FBO mean your order is met, quietly, exactly, at any hour.</p>
    <div style="margin-top:50px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/contact#contact">Speak With Dispatch</a></div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Answers</span>
    <h2 class="type-h2" style="margin:20px 0 40px;">Frequently asked</h2>
    <div class="jc-faq">
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">How quickly can you deliver catering to the aircraft?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">We deliver directly to the apron and FBO at Bali Ngurah Rai. Standard lead times begin at six hours, and urgent turnarounds are accommodated around the clock through our dispatch desk.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Which airport and terminals do you serve?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">We operate at Ngurah Rai International (DPS/WADD), delivering to ExecuJet General Aviation Terminal and to other FBOs, handlers and general aviation terminals across the airport.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Can you accommodate specialized diets and allergens?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Yes. Halal, vegan, keto, low-sodium, medical and fully allergen-safe menus are prepared in a HACCP-controlled kitchen with per-passenger labelling.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">How are meals packaged for flight?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Meals use flight-ready, high-vacuum packaging engineered for low-humidity cabins, labelled per passenger and crew, with reheating guidance for the galley.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">What are your hours and how do we place an order?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Dispatch operates 24/7. Send flight details and F&B requests through the order form or the dispatch hotline. Last-minute manifest changes are expected and handled.</p></div>
      </details>
    </div>
  </section>

  <SisterBrands
    current="jet"
    heading="Operating on the water?"
    intro="Catering or provisioning a yacht or superyacht in Bali? Our sister brands deliver the same standard dockside, from charter dining to full maritime procurement."
  />
</PageLayout>

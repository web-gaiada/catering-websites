---
import PageLayout from "@bali/ui/components/PageLayout.astro";
import ImagePlate from "@bali/ui/components/ImagePlate.astro";
import SisterBrands from "@bali/ui/components/SisterBrands.astro";
import { yacht, yachtGeo } from "../brand";
import { img } from "../lib/images";

// Booking form destination — see the inline script at the bottom of this page.
const contactEndpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: "Booking & Inquiries — Bali Yacht Catering",
    url: "https://baliyachtcatering.com/booking",
    description: "Request a customized yacht catering quote for a charter or private ocean event in Bali.",
    mainEntity: {
      "@type": "Organization",
      name: "Bali Yacht Catering",
      url: "https://baliyachtcatering.com",
      contactPoint: [
        {
          "@type": "ContactPoint",
          telephone: "+62-811-0000-111",
          contactType: "Bookings & inquiries",
          availableLanguage: ["English", "Indonesian"],
        },
      ],
    },
  },
];
---

<PageLayout
  brand={yacht}
  current="booking"
  cta={{ label: "Call Us", href: "tel:+628110000111" }}
  title="Request a Yacht Catering Quote | Bali Boat Events"
  description="Plan your onboard dining experience. Contact Bali's premier yacht catering service for a customized menu quote for your upcoming charter or private ocean event."
  canonical="https://baliyachtcatering.com/booking"
  geo={yachtGeo}
  jsonLd={jsonLd}
>
  <section class="jc-hero section-tone--dark" data-screen-label="Yacht · Booking" style="min-height:58vh;">
    <ImagePlate hero image={img("yacht-booking-hero")} caption="Guests dining on deck at sunset" />
    <div class="jc-hero__scrim"></div>
    <div class="jc-hero__inner">
      <div class="jc-hero__col">
        <span class="type-eyebrow" style="display:block; margin-bottom:30px; opacity:0.82;">Booking & Inquiries</span>
        <h1 class="type-h1" style="font-size:clamp(38px,5vw,60px); line-height:1.05; max-width:20ch;">Book Your Luxury Yacht Catering Experience</h1>
        <p class="type-body-lg" style="opacity:0.84; margin-top:30px; max-width:60ch;">Tell us about your charter and we will design the menu and crew to match — with fast, clear quotes for private guests and charter agencies alike.</p>
      </div>
    </div>
  </section>

  <section class="section-tone--paper Section">
    <div class="jc-contact">
      <div>
        <span class="type-eyebrow" style="display:block; color:var(--accent);">Customize Your Marine Event Menu</span>
        <h2 class="type-h2" style="margin:20px 0 30px;">Request a quote</h2>

        <form data-contact-form method="POST" action={contactEndpoint || "#"} novalidate>
          <div class="jc-form-grid">
            <div class="luxury-field">
              <input id="f-name" class="luxury-field__input" name="name" placeholder=" " required />
              <label for="f-name" class="luxury-field__label">Full name</label>
            </div>
            <div class="luxury-field">
              <input id="f-company" class="luxury-field__input" name="company" placeholder=" " />
              <label for="f-company" class="luxury-field__label">Company / charter agency</label>
            </div>
            <div class="luxury-field">
              <input id="f-email" type="email" class="luxury-field__input" name="email" placeholder=" " required />
              <label for="f-email" class="luxury-field__label">Email</label>
            </div>
            <div class="luxury-field">
              <input id="f-phone" class="luxury-field__input" name="phone" placeholder=" " required />
              <label for="f-phone" class="luxury-field__label">Phone / WhatsApp</label>
            </div>
            <div class="luxury-field">
              <input id="f-vessel" class="luxury-field__input" name="vessel" placeholder=" " />
              <label for="f-vessel" class="luxury-field__label">Vessel / charter type</label>
            </div>
            <div class="luxury-field">
              <input id="f-marina" class="luxury-field__input" name="marina" placeholder=" " value="Benoa Marina" />
              <label for="f-marina" class="luxury-field__label">Marina / pickup point</label>
            </div>
            <div class="luxury-field">
              <input id="f-date" class="luxury-field__input" name="date" placeholder=" " />
              <label for="f-date" class="luxury-field__label">Charter date</label>
            </div>
            <div class="luxury-field">
              <input id="f-guests" class="luxury-field__input" name="guests" placeholder=" " />
              <label for="f-guests" class="luxury-field__label">Number of guests</label>
            </div>
          </div>
          <div class="luxury-field" style="margin-top:0;">
            <input id="f-diet" class="luxury-field__input" name="diet" placeholder=" " />
            <label for="f-diet" class="luxury-field__label">Dietary & beverage preferences</label>
          </div>
          <div class="luxury-field">
            <textarea id="f-event" class="luxury-field__input" name="event" placeholder=" " required rows="4" style="resize:vertical;"></textarea>
            <label for="f-event" class="luxury-field__label">Tell us about your event</label>
          </div>
          <p class="type-caption" style="margin:20px 0 0; color:var(--accent); opacity:0.6;">We will only use these details to prepare your quote — never anything more.</p>
          <div style="margin-top:30px;">
            <button type="submit" class="luxury-btn luxury-btn--solid luxury-btn--md">Request a Quote</button>
          </div>
        </form>

        <div data-contact-success hidden style="border:0.5px solid color-mix(in srgb, var(--hairline) 18%, transparent); padding:50px;">
          <span class="type-eyebrow" style="display:block; color:var(--accent);">Inquiry received</span>
          <h3 class="type-h3" style="margin:15px 0 0;">Thank you — we have your charter details.</h3>
          <p class="type-body-md" style="margin:15px 0 0; opacity:0.78; max-width:48ch;">A coordinator will reply with a tailored menu and quote shortly. For a charter departing soon, message us directly on +62 811 0000 111.</p>
          <div style="margin-top:30px;">
            <button type="button" class="luxury-btn luxury-btn--ghost luxury-btn--md" data-contact-reset>Submit Another</button>
          </div>
        </div>
      </div>

      <aside>
        <span class="type-eyebrow" style="display:block; color:var(--accent);">Fast Quotes for Charter Agencies and Private Guests</span>
        <h2 class="type-h2" style="margin:20px 0 30px;">Get in touch</h2>
        <div style="display:flex; flex-direction:column; gap:30px;">
          <div>
            <span class="type-eyebrow" style="opacity:0.6;">Bookings</span>
            <a href="tel:+628110000111" class="type-h3" style="display:block; margin-top:8px; text-decoration:none; color:var(--text-primary);">+62 811 0000 111</a>
          </div>
          <hr class="luxury-separator luxury-separator--h" />
          <div>
            <span class="type-eyebrow" style="opacity:0.6;">Email</span>
            <a href="mailto:info@baliyachtcatering.com" class="type-body-lg" style="display:block; margin-top:8px; text-decoration:none; color:var(--text-primary);">info@baliyachtcatering.com</a>
          </div>
          <hr class="luxury-separator luxury-separator--h" />
          <div>
            <span class="type-eyebrow" style="opacity:0.6;">Pickup</span>
            <p class="type-body-md" style="margin:8px 0 0;">Benoa Marina & charter anchorages<br />Bali, Indonesia</p>
          </div>
          <hr class="luxury-separator luxury-separator--h" />
          <div>
            <span class="type-eyebrow" style="opacity:0.6;">Response</span>
            <p class="type-body-md" style="margin:8px 0 0;">Tailored menu and quote within the day. Agency rates available on request.</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <SisterBrands
    current="yacht"
    heading="Flying private or running a superyacht?"
    intro="Our sister brands deliver the same standard in the air and at the dock."
  />
</PageLayout>

<script>
  // Booking form. With PUBLIC_CONTACT_ENDPOINT set, posts via fetch and shows
  // the confirmation panel; without it, runs in demo mode (confirm UI only).
  (function () {
    const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
    const success = document.querySelector<HTMLElement>("[data-contact-success]");
    const reset = document.querySelector<HTMLElement>("[data-contact-reset]");
    if (!form || !success) return;

    const showSuccess = () => {
      form.hidden = true;
      success.hidden = false;
      window.scrollTo({ top: 0, behavior: "smooth" });
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const endpoint = form.getAttribute("action");
      if (endpoint && endpoint !== "#") {
        try {
          await fetch(endpoint, {
            method: "POST",
            body: new FormData(form),
            headers: { Accept: "application/json" },
          });
        } catch {
          /* swallow — still confirm; provider may also redirect */
        }
      }
      showSuccess();
    });

    reset?.addEventListener("click", () => {
      success.hidden = true;
      form.hidden = false;
      form.reset();
    });
  })();
</script>

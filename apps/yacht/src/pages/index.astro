---
import PageLayout from "@bali/ui/components/PageLayout.astro";
import ImagePlate from "@bali/ui/components/ImagePlate.astro";
import SisterBrands from "@bali/ui/components/SisterBrands.astro";
import { yacht, yachtGeo } from "../brand";
import { img } from "../lib/images";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FoodEstablishment",
    name: "Bali Yacht Catering",
    description:
      "Luxury yacht catering for day charters, sunset cruises and private marine events in Bali, with onboard chefs and five-star hospitality.",
    url: "https://baliyachtcatering.com",
    telephone: "+62-811-3821-0187",
    servesCuisine: ["Seafood", "International", "Indonesian", "Canapés"],
    priceRange: "$$$$",
    areaServed: "Bali: Benoa Marina, Serangan & charter anchorages",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Komplek Ruko Wayang Sanur, Jl. Bypass Ngurah Rai",
      addressLocality: "Sanur, Denpasar",
      addressRegion: "Bali",
      postalCode: "80227",
      addressCountry: "ID",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Do you deliver to the marina or cater onboard?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Both. We deliver dockside at Benoa and other Bali marinas, and our team can board the vessel to plate, serve and tend bar underway.",
        },
      },
      {
        "@type": "Question",
        name: "What size charters do you cater?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "From intimate day charters and sunset cruises to large catamaran parties and superyacht celebrations.",
        },
      },
      {
        "@type": "Question",
        name: "Can you provide onboard chefs and service staff?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. We supply private chefs, mixologists and five-star service crew, matched to the vessel and the occasion.",
        },
      },
      {
        "@type": "Question",
        name: "How far ahead should we book?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Forty-eight hours is ideal for bespoke menus, though we routinely accommodate shorter notice for charters and last-minute guests.",
        },
      },
      {
        "@type": "Question",
        name: "Do you handle dietary needs and open bar?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We cover the full dietary range and provide premium beverage packages, open bar and marine mixology.",
        },
      },
    ],
  },
];
---

<PageLayout
  brand={yacht}
  current="home"
  title="Bali Yacht Catering"
  description="Premium yacht catering for day charters, sunset cruises, and private events in Bali. Award-winning onboard chefs, luxury finger foods, and bespoke ocean dining."
  canonical="https://baliyachtcatering.com/"
  geo={yachtGeo}
  jsonLd={jsonLd}
>
  <section class="jc-hero section-tone--dark" data-screen-label="Yacht · Home">
    <ImagePlate hero image={img("yacht-home-hero")} caption="Yacht at sunset off Bali" />
    <div class="jc-hero__scrim"></div>
    <div class="jc-hero__inner">
      <div class="jc-hero__col">
        <span class="type-eyebrow" style="display:block; margin-bottom:30px; opacity:0.82;">Yacht Catering & Onboard Dining · Bali</span>
        <h1 class="type-h1" style="font-size:clamp(40px,5.6vw,68px); line-height:1.04; max-width:18ch;">Luxury Yacht Catering & Private Boat Event Dining in Bali</h1>
        <p class="type-body-lg" style="opacity:0.84; margin-top:30px; max-width:60ch;">Bespoke onboard dining for day charters, sunset cruises and private celebrations, prepared by professional chefs and served with five-star marine hospitality.</p>
        <div style="display:flex; gap:20px; margin-top:60px; flex-wrap:wrap;">
          <a class="luxury-btn luxury-btn--solid luxury-btn--md" href="/booking#book-luxury-yacht">Request a Quote</a>
          <a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/menus#luxury-platters">View Menus</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Bespoke Culinary Experiences on the Indian Ocean</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:20ch;">Dining that belongs to the water</h2>
    <p class="type-body-lg" style="margin:30px 0 0; max-width:64ch;">We design every menu around the vessel, the route and the occasion, from barefoot canapés on a catamaran to a plated dinner at anchor. Delivered dockside or cooked onboard, always to a five-star standard.</p>
    <div class="jc-meta" style="margin-top:50px;">
      <span class="type-eyebrow" style="color:var(--accent);">Benoa & Marina Pickup</span>
      <span class="type-eyebrow dot">/</span>
      <span class="type-eyebrow" style="color:var(--accent);">Onboard Chefs</span>
      <span class="type-eyebrow dot">/</span>
      <span class="type-eyebrow" style="color:var(--accent);">Five-Star Service</span>
      <span class="type-eyebrow dot">/</span>
      <span class="type-eyebrow" style="color:var(--accent);">Bespoke Menus</span>
    </div>
  </section>

  <section class="section-tone--tint Section">
    <div class="jc-split">
      <div class="jc-split--text">
        <span class="type-eyebrow" style="display:block; color:var(--accent);">Day Charters, Sunset Cruises & Marine Celebrations</span>
        <h2 class="type-h2" style="margin:20px 0 0;">Catering matched to the charter</h2>
        <p class="type-body-md" style="margin:30px 0 0;">A long lunch under sail, a sunset cruise with Champagne and canapés, a milestone celebration at anchor: we scale and style the catering to the day, the guest list and the vessel.</p>
        <div style="margin-top:40px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/menus#luxury-platters">Explore Menus</a></div>
      </div>
      <ImagePlate image={img("yacht-home-plate1")} caption="Onboard dining / canapés" ratio="4 / 3" />
    </div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Professional Onboard Chefs & Five-Star Marine Hospitality</span>
    <h2 class="type-h2" style="margin:20px 0 0; max-width:22ch;">Every occasion on the water</h2>
    <div class="luxury-card-grid" style="--cols:3; margin-top:50px;">
      <article class="luxury-card">
        <h3 class="luxury-card__title">Day Charters & Catamarans</h3>
        <p class="luxury-card__body">Grazing platters, fresh seafood and barefoot canapés delivered for the cruise, styled for relaxed dining on deck.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/menus#luxury-platters">View Menus</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Sunset Cruises</h3>
        <p class="luxury-card__body">Champagne, canapés and a marine mixology bar timed to golden hour, served by professional crew underway.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/onboard-chefs#marine-hospitality">Onboard Service</a></div>
      </article>
      <article class="luxury-card">
        <h3 class="luxury-card__title">Marine Celebrations</h3>
        <p class="luxury-card__body">Weddings, birthdays and corporate days at sea: plated fine dining and live BBQ with full event styling.</p>
        <div class="luxury-card__actions"><a class="luxury-btn luxury-btn--ghost luxury-btn--sm" href="/booking#book-luxury-yacht">Plan an Event</a></div>
      </article>
    </div>
  </section>

  <section class="section-tone--dark Section" style="text-align:center;">
    <span class="type-eyebrow" style="display:block; opacity:0.82;">The Standard</span>
    <h2 class="type-h2" style="font-size:clamp(28px,4vw,46px); line-height:1.12; max-width:26ch; margin:30px auto 0;">Five-star dining, from the galley to the last light on the water.</h2>
    <p class="type-body-lg" style="opacity:0.82; max-width:58ch; margin:30px auto 0;">Award-winning chefs, polished service crew and menus built for the sea, so the only thing you plan is the route.</p>
    <div style="margin-top:50px;"><a class="luxury-btn luxury-btn--ghost luxury-btn--md" href="/booking#book-luxury-yacht">Book Your Experience</a></div>
  </section>

  <section class="section-tone--paper Section">
    <span class="type-eyebrow" style="display:block; color:var(--accent);">Answers</span>
    <h2 class="type-h2" style="margin:20px 0 40px;">Frequently asked</h2>
    <div class="jc-faq">
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Do you deliver to the marina or cater onboard?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Both. We deliver dockside at Benoa and other Bali marinas, and our team can board the vessel to plate, serve and tend bar underway.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">What size charters do you cater?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">From intimate day charters and sunset cruises to large catamaran parties and superyacht celebrations.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Can you provide onboard chefs and service staff?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Yes. We supply private chefs, mixologists and five-star service crew, matched to the vessel and the occasion.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">How far ahead should we book?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">Forty-eight hours is ideal for bespoke menus, though we routinely accommodate shorter notice for charters and last-minute guests.</p></div>
      </details>
      <details name="jc-faq">
        <summary><span class="type-h3" style="font-size:21px; line-height:1.3;">Do you handle dietary needs and open bar?</span></summary>
        <div class="jc-faq__a"><p class="type-body-md" style="opacity:0.78;">We cover the full dietary range and provide premium beverage packages, open bar and marine mixology.</p></div>
      </details>
    </div>
  </section>

  <SisterBrands
    current="yacht"
    heading="Flying private or running a superyacht?"
    intro="Our sister brands deliver the same standard in the air and at the dock, from private jet catering to full superyacht provisioning."
  />
</PageLayout>

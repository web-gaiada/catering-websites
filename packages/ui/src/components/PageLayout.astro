---
/* =====================================================================
   PageLayout — the standard brand-site page shell: BaseLayout (head/SEO)
   wrapping Header + <main class="site-main"> + Footer. A brand page only
   provides its Brand, current nav key, SEO, and section content.
   ===================================================================== */
import BaseLayout from "./BaseLayout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import type { Brand } from "../brand";

export interface Props {
  brand: Brand;
  /** Current nav key (aria-current + drives the active link). */
  current: string;
  /** Optional header CTA override (defaults to brand.cta). */
  cta?: { label: string; href: string };
  title: string;
  description: string;
  canonical: string;
  ogType?: string;
  /** Override robots directive (e.g. "noindex, follow" for the 404 page). */
  robots?: string;
  geo?: { region?: string; placename?: string; position?: string };
  jsonLd?: Record<string, unknown>[];
}
const { brand, current, cta, title, description, canonical, ogType, robots, geo, jsonLd } = Astro.props;
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  siteName={brand.name}
  ogType={ogType}
  robots={robots}
  geo={geo}
  jsonLd={jsonLd}
>
  <Header brand={brand} current={current} cta={cta} />
  <main class="site-main">
    <slot />
  </main>
  <Footer brand={brand} />
</BaseLayout>

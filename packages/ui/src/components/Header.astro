---
/* =====================================================================
   Header — shared across all brand sites; themed per brand by the Brand
   config. Renders the 80px overlay bar, desktop nav, CTA, and the mobile
   hamburger + slide-out drawer. The scroll engine (transparent → solid on
   scroll) and the drawer open/close live in the bundled client script below —
   the DC source expressed these via a React DCLogic component.
   ===================================================================== */
import type { Brand, SocialIcon } from "../brand";

export interface Props {
  brand: Brand;
  /** Nav key of the current page (for aria-current). */
  current: string;
  /** Optional CTA override (e.g. "Call Dispatch" on the contact page). */
  cta?: { label: string; href: string };
  /** Transparent overlay bar over an immersive hero (default true). */
  overlay?: boolean;
}
const { brand, current, cta = brand.cta, overlay = true } = Astro.props;

// Lucide-weight stroke icons, inlined (CSP-safe, no CDN).
const ICONS: Record<SocialIcon, string> = {
  linkedin:
    '<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="7" y1="10" x2="7" y2="17"/><circle cx="7" cy="6.7" r="0.7" fill="currentColor" stroke="none"/><path d="M11 17v-4a2.5 2.5 0 0 1 5 0v4"/><line x1="11" y1="10" x2="11" y2="17"/>',
  instagram:
    '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none"/>',
  facebook:
    '<path d="M14 8.5h2.5V5.5H14c-2 0-3 1.4-3 3.2V11H9v3h2v6h3v-6h2.3l.4-3H14V9.1c0-.4.2-.6.6-.6Z"/>',
  youtube:
    '<rect x="3" y="6" width="18" height="12" rx="3"/><path d="M10.5 9.5v5l4.5-2.5z" fill="currentColor" stroke="none"/>',
};
const headerClasses = [
  "luxury-header",
  "luxury-header--sticky",
  overlay && "luxury-header--overlay",
].filter(Boolean).join(" ");
---
<header class={headerClasses}>
  <div class="luxury-header__inner">
    <a class="luxury-header__brand" href="/">
      <span class="luxury-header__logo-word">{brand.name}</span>
    </a>
    <nav class="luxury-header__nav" aria-label="Primary">
      {
        brand.nav.map((item) => {
          const groupActive =
            item.key === current || item.children?.some((c) => c.key === current);
          return item.children && item.children.length > 0 ? (
            <div class="luxury-header__navitem luxury-header__navitem--menu">
              <button
                type="button"
                class="luxury-header__link luxury-header__link--menu"
                aria-current={groupActive ? "page" : undefined}
                aria-haspopup="true"
                aria-expanded="false"
                data-dropdown-toggle
              >
                {item.label}
                <span class="luxury-header__caret" aria-hidden="true"></span>
              </button>
              <div class="luxury-header__submenu" role="menu">
                {item.children.map((child) => (
                  <a
                    class="luxury-header__submenu-link"
                    href={child.href}
                    role="menuitem"
                    aria-current={child.key === current ? "page" : undefined}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              class="luxury-header__link"
              href={item.href}
              aria-current={item.key === current ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
    <div class="luxury-header__actions">
      <a class="luxury-btn luxury-btn--ghost luxury-btn--md" href={cta.href}>{cta.label}</a>
      {
        brand.social.map((s) => (
          <a class="luxury-icon-btn" href={s.href} aria-label={s.label}>
            <span class="luxury-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" set:html={ICONS[s.icon]} />
            </span>
          </a>
        ))
      }
    </div>
    <button type="button" class="luxury-header__burger" aria-label="Open menu" aria-expanded="false" data-nav-open>
      <span class="luxury-header__burger-bars" aria-hidden="true"></span>
    </button>
  </div>
</header>

<div class="luxury-nav" hidden data-nav-root>
  <div class="luxury-nav-overlay" data-nav-close></div>
  <div class="luxury-nav-drawer" role="dialog" aria-modal="true" aria-label="Menu">
    <button type="button" class="luxury-nav-drawer__close" aria-label="Close menu" data-nav-close>
      <span style="font-family:var(--font-body); font-size:26px; line-height:1;">&times;</span>
    </button>
    <nav class="luxury-nav-drawer__links" aria-label="Mobile">
      {
        brand.nav.map((item) =>
          item.children && item.children.length > 0 ? (
            <div class="luxury-nav-drawer__group">
              <button
                type="button"
                class="luxury-nav-drawer__grouplabel"
                data-drawer-group-toggle
                aria-haspopup="true"
                aria-expanded="false"
              >
                {item.label}
                <span class="luxury-nav-drawer__caret" aria-hidden="true"></span>
              </button>
              <div class="luxury-nav-drawer__sublinks">
                <div class="luxury-nav-drawer__sublinks-inner">
                  {item.children.map((child) => (
                    <a
                      class="luxury-nav-drawer__link luxury-nav-drawer__sublink"
                      href={child.href}
                      aria-current={child.key === current ? "page" : undefined}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              class="luxury-nav-drawer__link"
              href={item.href}
              aria-current={item.key === current ? "page" : undefined}
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>
    <div class="luxury-nav-drawer__actions">
      <a class="luxury-btn luxury-btn--solid luxury-btn--md" href={cta.href}>{cta.label}</a>
      {
        brand.social.length > 0 && (
          <div class="luxury-nav-drawer__social">
            {brand.social.map((s) => (
              <a class="luxury-icon-btn" href={s.href} aria-label={s.label}>
                <span class="luxury-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" set:html={ICONS[s.icon]} />
                </span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</div>

<script>
  // Smart header + mobile drawer. Runs once per page (Header is included once).
  (function () {
    const header = document.querySelector<HTMLElement>(".luxury-header");
    if (header) {
      const onScroll = () =>
        header.classList.toggle("is-scrolled", window.scrollY > 20);
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }

    const root = document.querySelector<HTMLElement>("[data-nav-root]");
    const overlay = root?.querySelector<HTMLElement>(".luxury-nav-overlay");
    const drawer = root?.querySelector<HTMLElement>(".luxury-nav-drawer");
    const burger = document.querySelector<HTMLElement>("[data-nav-open]");
    if (!root || !overlay || !drawer || !burger) return;

    let closeTimer: number | undefined;
    const open = () => {
      window.clearTimeout(closeTimer);
      document.body.style.overflow = "hidden";
      root.hidden = false;
      burger.setAttribute("aria-expanded", "true");
      // next frame so the slide/fade transition plays from the rest state
      requestAnimationFrame(() => {
        overlay.classList.add("is-open");
        drawer.classList.add("is-open");
      });
    };
    const close = () => {
      document.body.style.overflow = "";
      overlay.classList.remove("is-open");
      drawer.classList.remove("is-open");
      burger.setAttribute("aria-expanded", "false");
      closeTimer = window.setTimeout(() => {
        root.hidden = true;
      }, 300);
    };

    burger.addEventListener("click", open);
    root.querySelectorAll("[data-nav-close]").forEach((el) =>
      el.addEventListener("click", close)
    );
    // Tapping a drawer link navigates; close so it isn't left open on return.
    drawer.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
    // Dropdown groups in the drawer: the label toggles its sublinks open/closed.
    drawer.querySelectorAll("[data-drawer-group-toggle]").forEach((toggle) => {
      toggle.addEventListener("click", () => {
        const group = toggle.closest<HTMLElement>(".luxury-nav-drawer__group");
        if (!group) return;
        const willOpen = !group.classList.contains("is-open");
        group.classList.toggle("is-open", willOpen);
        toggle.setAttribute("aria-expanded", willOpen ? "true" : "false");
      });
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !root.hidden) close();
    });
  })();

  // Desktop dropdown: the parent is a toggle button, not a link. It is closed by
  // default; a click opens/closes the panel. Escape and an outside click close
  // any open menu.
  (function () {
    const toggles = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-dropdown-toggle]"),
    );
    if (!toggles.length) return;

    const itemOf = (t: Element) => t.closest<HTMLElement>(".luxury-header__navitem");
    const closeAll = (except?: HTMLElement | null) => {
      toggles.forEach((t) => {
        const item = itemOf(t);
        if (!item || item === except) return;
        item.classList.remove("is-open");
        t.setAttribute("aria-expanded", "false");
      });
    };

    toggles.forEach((toggle) => {
      toggle.addEventListener("click", () => {
        const item = itemOf(toggle);
        if (!item) return;
        const willOpen = !item.classList.contains("is-open");
        closeAll(item);
        item.classList.toggle("is-open", willOpen);
        toggle.setAttribute("aria-expanded", willOpen ? "true" : "false");
      });
    });

    document.addEventListener("click", (e) => {
      const target = e.target;
      if (!(target instanceof Element) || !target.closest(".luxury-header__navitem--menu")) {
        closeAll();
      }
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAll();
    });
  })();
</script>

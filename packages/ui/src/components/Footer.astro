---
/* =====================================================================
   Footer — shared across all brand sites; content from the Brand config.
   Brand wordmark + address + social on the left; link columns to the right;
   © line locked to the bottom. (Footer ignores the zebra rhythm — paper.)
   ===================================================================== */
import type { Brand, SocialIcon } from "../brand";

export interface Props {
  brand: Brand;
}
const { brand } = Astro.props;
const { footer } = brand;

// Lucide-weight stroke icons, inlined (CSP-safe, no CDN).
const ICONS: Record<SocialIcon, string> = {
  linkedin:
    '<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="7" y1="10" x2="7" y2="17"/><circle cx="7" cy="6.7" r="0.7" fill="currentColor" stroke="none"/><path d="M11 17v-4a2.5 2.5 0 0 1 5 0v4"/><line x1="11" y1="10" x2="11" y2="17"/>',
  instagram:
    '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none"/>',
  facebook:
    '<path d="M14 8.5h2.5V5.5H14c-2 0-3 1.4-3 3.2V11H9v3h2v6h3v-6h2.3l.4-3H14V9.1c0-.4.2-.6.6-.6Z"/>',
  youtube:
    '<rect x="3" y="6" width="18" height="12" rx="3"/><path d="M10.5 9.5v5l4.5-2.5z" fill="currentColor" stroke="none"/>',
};
---
<footer class="luxury-footer">
  <div class="luxury-footer__inner">
    <div class="luxury-footer__brand-col">
      <span class="luxury-footer__logo">{brand.name}</span>
      <div class="luxury-footer__address">
        {footer.address.lines.map((line) => <span>{line}</span>)}
        {footer.address.phone && <a href={footer.address.phone.href}>{footer.address.phone.label}</a>}
        {footer.address.email && <a href={footer.address.email.href}>{footer.address.email.label}</a>}
      </div>
      {
        footer.social.length > 0 && (
          <div class="luxury-footer__social">
            {footer.social.map((s) => (
              <a class="luxury-icon-btn" href={s.href} aria-label={s.label}>
                <span class="luxury-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" set:html={ICONS[s.icon]} />
                </span>
              </a>
            ))}
          </div>
        )
      }
    </div>
    {
      footer.columns.map((col) => (
        <nav class="luxury-footer__col" aria-label={col.title}>
          <span class="luxury-footer__col-title">{col.title}</span>
          <div class="luxury-footer__links">
            {col.links.map((link) => (
              <a
                class="luxury-footer__link"
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener" : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
        </nav>
      ))
    }
  </div>
  <div class="luxury-footer__base">
    <span class="luxury-footer__copy" set:html={footer.copyright}></span>
  </div>
</footer>

---
/* =====================================================================
   Footer — shared across all brand sites; content from the Brand config.
   Brand wordmark + address on the left; link columns to the right;
   © line locked to the bottom. (Footer ignores the zebra rhythm — paper.)
   ===================================================================== */
import type { Brand } from "../brand";

export interface Props {
  brand: Brand;
}
const { brand } = Astro.props;
const { footer } = brand;
---
<footer class="luxury-footer">
  <div class="luxury-footer__inner">
    <div class="luxury-footer__brand-col">
      <span class="luxury-footer__logo">{brand.name}</span>
      <div class="luxury-footer__address">
        {footer.address.lines.map((line) => <span>{line}</span>)}
        {footer.address.phone && <a href={footer.address.phone.href}>{footer.address.phone.label}</a>}
        {footer.address.email && <a href={footer.address.email.href}>{footer.address.email.label}</a>}
      </div>
    </div>
    {
      footer.columns.map((col) => (
        <nav class="luxury-footer__col" aria-label={col.title}>
          <span class="luxury-footer__col-title">{col.title}</span>
          <div class="luxury-footer__links">
            {col.links.map((link) => (
              <a
                class="luxury-footer__link"
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener" : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
        </nav>
      ))
    }
  </div>
  <div class="luxury-footer__base">
    <span class="luxury-footer__copy" set:html={footer.copyright}></span>
  </div>
</footer>
